# ============================================================
#  HAAR. Voedingsadvies — omgevingsvariabelen
#  Kopieer dit bestand naar .env en vul je eigen sleutels in.
#  Het .env bestand NOOIT committen naar Git!
# ============================================================

# Stripe API-sleutels — te vinden op https://dashboard.stripe.com/apikeys
# Gebruik sk_test_... en pk_test_... tijdens ontwikkeling
# Gebruik sk_live_... en pk_live_... in productie

STRIPE_SECRET_KEY=sk_test_VERVANG_MET_JOUW_GEHEIME_SLEUTEL
STRIPE_PUBLISHABLE_KEY=pk_test_VERVANG_MET_JOUW_PUBLIEKE_SLEUTEL

# Stripe Webhook-geheim (optioneel, voor payment_intent.succeeded webhook)
# Aanmaken via: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_VERVANG_MET_JOUW_WEBHOOK_GEHEIM

# Poort waarop de server draait (standaard 3000)
PORT=3000

# Gmail SMTP voor het versturen van rapporten
# Gebruik een Google App Password (niet je gewone wachtwoord)
# Aanmaken via: https://myaccount.google.com/apppasswords
SMTP_USER=haarkattentrimsalon@gmail.com
SMTP_PASS=VERVANG_MET_APP_PASSWORD
